import { Zip, ZipDeflate, ZipPassThrough } from 'fflate';

onmessage = async (e) => {
  const { rootHandle } = e.data; // The OPFS DirectoryHandle

  const stream = new ReadableStream({
    async start(controller) {
      // 1. Initialize fflate Zip engine
      const zip = new Zip();

      // When fflate has a chunk of the ZIP ready, push it to the stream
      zip.ondata = (err, chunk, final) => {
        if (err) controller.error(err);
        else {
          controller.enqueue(chunk);
          if (final) controller.close();
        }
      };

      try {
        // 2. Add the SQLite Database (Deflate/Compress)
        const dbFile = await (await rootHandle.getFileHandle('db.sqlite3')).getFile();
        const dbStream = new ZipDeflate('db.sqlite3', { level: 6 });
        zip.add(dbStream);
        await streamToFflate(dbFile, dbStream);

        // 3. Add Images (PassThrough / Level 0 - because WebP is already compressed)
        const imagesDir = await rootHandle.getDirectoryHandle('images');
        for await (const entry of imagesDir.values()) {
          if (entry.kind === 'file') {
            const file = await entry.getFile();
            // level: 0 saves significant CPU by not re-compressing WebPs
            const imgStream = new ZipPassThrough(file.name);
            zip.add(imgStream);
            await streamToFflate(file, imgStream);
          }
        }

        // 4. Finalize the ZIP
        zip.end();
      } catch (err) {
        controller.error(err);
      }
    }
  });

  // Transfer the stream to the main thread
  postMessage({ stream }, [stream]);
};

/**
 * Helper to feed a File into an fflate stream chunk-by-chunk
 * This ensures we never hold the whole file in RAM.
 */
async function streamToFflate(file, fflateStream) {
  const reader = file.stream().getReader();
  while (true) {
    const { done, value } = await reader.read();
    if (done) {
      fflateStream.terminate(); // Tell fflate this specific file is done
      break;
    }
    fflateStream.push(value);
  }
}