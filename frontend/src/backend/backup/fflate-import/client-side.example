async importFromStream(stream: ReadableStream<Uint8Array>): Promise<void> {
  const files = await this.#inflateZipStream(stream);
  // ... rest identical
}

async #inflateZipStream(
  stream: ReadableStream<Uint8Array>,
): Promise<Map<string, Uint8Array>> {
  const files = new Map<string, Uint8Array>();

  return new Promise<Map<string, Uint8Array>>((resolve, reject) => {
    const unzip = new Unzip();
    unzip.register(UnzipInflate);

    unzip.onfile = (stream) => {
      const chunks: Uint8Array[] = [];
      stream.ondata = (err, chunk, final) => {
        if (err) { reject(err); return; }
        chunks.push(chunk.slice());
        if (final) {
          const total = chunks.reduce((s, c) => s + c.length, 0);
          const merged = new Uint8Array(total);
          let offset = 0;
          for (const c of chunks) {
            merged.set(c, offset);
            offset += c.length;
          }
          files.set(stream.name, merged);
        }
      };
      stream.start();
    };

    const reader = stream.getReader();
    const pump = async () => {
      while (true) {
        const { value, done } = await reader.read();
        if (done) {
          unzip.push(new Uint8Array(0), true);
          resolve(files);
          return;
        }
        unzip.push(value, false);
      }
    };

    pump().catch(reject);
  });
}
